<Window x:Class="TemplateMethod_Bebidas.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:TemplateMethod_Bebidas.ViewModels"
        Title="Template Method — Preparo de Bebidas"
        Height="350" Width="400"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <StackPanel Margin="20">

        <TextBlock Text=" Preparo de Bebidas"
                   FontSize="20" FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"/>

        <TextBlock Text="Escolha uma bebida para preparar:"
                   Margin="0,0,0,10"/>

        <Button Content="Preparar Café"
                Height="40" Margin="0,0,0,10"
                Command="{Binding PrepararCafeCommand}"/>

        <Button Content="Preparar Chá"
                Height="40" Margin="0,0,0,20"
                Command="{Binding PrepararChaCommand}"/>

        <TextBlock Text="Log de preparo:" Margin="0,0,0,5"/>

        <TextBox Height="120"
                 IsReadOnly="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 Background="#F5F5F5"
                 Padding="8"
                 Text="{Binding Log}"/>

    </StackPanel>
</Window>